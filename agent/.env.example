# ── 模型提供方 ──────────────────────────────────────────
AGENT_MODEL_PROVIDER=ollama
AGENT_MODEL_BACKEND=openai_compatible_remote

# ── 连接配置 ──────────────────────────────────────────
AGENT_MODEL_API_KEY=ollama
AGENT_MODEL_CHAT_COMPLETIONS_URL=http://127.0.0.1:11434/v1/chat/completions
AGENT_MODEL_NAME=qwen3.5:4b
AGENT_MODEL_TIMEOUT_SECONDS=300

# ── 采样参数 ──────────────────────────────────────────
AGENT_MODEL_TEMPERATURE=0.6
AGENT_MODEL_TOP_P=0.95
AGENT_MODEL_TOP_K=20
AGENT_MODEL_MIN_P=0.0
AGENT_MODEL_PRESENCE_PENALTY=0.0
AGENT_MODEL_REPETITION_PENALTY=1.0
AGENT_MODEL_MAX_TOKENS=4096
AGENT_MODEL_N=1

# ── 输出格式 ──────────────────────────────────────────
AGENT_MODEL_FORCE_JSON_OUTPUT=false
PYTHONIOENCODING=utf-8

# ── 思考模式（可选，仅支持思考模型时启用）──────────────
AGENT_MODEL_ENABLE_THINKING=false
# AGENT_MODEL_THINKING_BUDGET=4096

# —— Markdown 长期记忆（默认关闭）——————————————————————
AGENT_MEMORY_ENABLED=false
AGENT_MEMORY_DIR=.agent_memory/profile
AGENT_MEMORY_MAX_CONTEXT_ITEMS=20

# —— 儿童教育 RAG 知识库（默认关闭）———————————————————
AGENT_KB_ENABLED=false
AGENT_KB_EMBED_BACKEND=ollama
AGENT_KB_OLLAMA_EMBED_URL=http://127.0.0.1:11434/api/embed
AGENT_KB_EMBED_MODEL=bge-m3
AGENT_KB_CHROMA_PATH=.agent_kb/chroma
AGENT_KB_COLLECTION=children_education
AGENT_KB_SOURCE_PATH=data/knowledge/grimms_fairy_tales.txt
AGENT_KB_TOP_K=5
AGENT_KB_MIN_SCORE=0.0
AGENT_KB_EMBED_TEXT_CHARS=120
